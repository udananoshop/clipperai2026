# ClipperAi2026 Backend Environment Variables

# Server Configuration
PORT=3001
BACKEND_PORT=3001

# JWT Secret (REQUIRED)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Database
DATABASE_URL=file:./dev.db

# Upload Settings
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=uploads

# Output Settings
OUTPUT_DIR=output
TEMP_DIR=temp

# AI Settings
AI_MAX_CONCURRENT_JOBS=3
AI_JOB_TIMEOUT=300000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
